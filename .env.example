# codex-openai-bridge local configuration
# Copy this file to `.env` for local startup.
# Request defaults are fixed in code: model=gpt-5.4, reasoning_effort=medium.

HOST=127.0.0.1
PORT=8787
LOCAL_BRIDGE_API_KEY=replace-me
SQLITE_PATH=.codex-openai-bridge/bridge.sqlite
# Optional override. Default: .codex-openai-bridge/workspaces/default-chat
# CODEX_WORKSPACE_ROOT=.codex-openai-bridge/workspaces/default-chat
BRIDGE_DISABLE_AUTH=false
BRIDGE_ENABLE_CWD_OVERRIDE=false
# Optional comma-separated absolute or relative roots when cwd override is enabled.
# BRIDGE_ALLOWED_CWD_ROOTS=.codex-openai-bridge/workspaces/default-chat
BRIDGE_LOG_MODE=dev-file
# Optional override. Default: log/dev
# BRIDGE_LOG_DIR=log/dev
# Optional content logging mode: none | errors-only | full. Default: none
# BRIDGE_LOG_CONTENT_MODE=none
# Optional preview length when content logging is enabled. Default: 2000
# BRIDGE_LOG_MAX_CONTENT_CHARS=2000
